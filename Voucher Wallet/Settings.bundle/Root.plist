<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>StringsTable</key>
    <string>Root</string>
    <key>PreferenceSpecifiers</key>
    <array>
        <!-- En-tête : À propos de l'apprentissage -->
        <dict>
            <key>Type</key>
            <string>PSGroupSpecifier</string>
            <key>Title</key>
            <string>Apprentissage automatique</string>
            <key>FooterText</key>
            <string>L'application apprend automatiquement vos préférences pour améliorer la détection des enseignes et des couleurs associées.</string>
        </dict>
        
        <!-- Lien vers la page Statistiques -->
        <dict>
            <key>Type</key>
            <string>PSChildPaneSpecifier</string>
            <key>Title</key>
            <string>Statistiques</string>
            <key>File</key>
            <string>Statistics</string>
        </dict>
        
        <!-- Section : Gestion des données -->
        <dict>
            <key>Type</key>
            <string>PSGroupSpecifier</string>
            <key>Title</key>
            <string>Gestion des données</string>
            <key>FooterText</key>
            <string>Activez cette option pour réinitialiser toutes les données d'apprentissage. Une confirmation vous sera demandée lors de la prochaine ouverture de l'app. Vos bons ne seront pas affectés.</string>
        </dict>
        
        <!-- Toggle pour demander la réinitialisation -->
        <dict>
            <key>Type</key>
            <string>PSToggleSwitchSpecifier</string>
            <key>Title</key>
            <string>Demande de réinitialisation</string>
            <key>Key</key>
            <string>reset_learning_requested</string>
            <key>DefaultValue</key>
            <false/>
        </dict>
        
        <!-- Section : À propos -->
        <dict>
            <key>Type</key>
            <string>PSGroupSpecifier</string>
            <key>Title</key>
            <string>À propos</string>
        </dict>
        
        <!-- Version de l'app -->
        <dict>
            <key>Type</key>
            <string>PSTitleValueSpecifier</string>
            <key>Title</key>
            <string>Version</string>
            <key>Key</key>
            <string>version_preference</string>
            <key>DefaultValue</key>
            <string>1.0</string>
        </dict>
    </array>
</dict>
</plist>

